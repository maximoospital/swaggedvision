---
import { Swiper, SwiperWrapper, SwiperSlide, SwiperButtonPrev, SwiperButtonNext } from "astro-swiper";
import { LightGallery } from 'astro-lightgallery';

interface Props {
  name: string;
  price: number;
  images: string[];
  url: string;
  category?: string;
  status?: 'available' | 'no_stock' | 'coming_soon' | 'ultimas';
}
const { name, price, images, url, category = '', status = 'available' } = Astro.props;

const galleryId = `lg-${Math.random().toString(36).slice(2, 11)}`;

const statusLabel: Record<string, string> = {
  no_stock:    'SIN STOCK',
  coming_soon: 'PROXIMO',
  ultimas:     'ULTIMAS!',
};
const isUnavailable = status === 'no_stock' || status === 'coming_soon';
const hasMultiple = images.length > 1;
---

<div
  class="clothing-card"
  data-name={name.toLowerCase()}
  data-category={category}
  data-status={status}
  data-pagefind-body
  data-pagefind-filter={category ? `category:${category}` : undefined}
>
  <div class="clothing-img-wrapper">
    {hasMultiple ? (
      <Swiper
        class="product-swiper"
        options={{ navigation: { nextEl: '.swiper-button-next', prevEl: '.swiper-button-prev' }, loop: true }}
      >
        <SwiperWrapper>
          {images.map((img, i) => (
            <SwiperSlide>
              <img
                src={img}
                alt={`${name} ${i + 1}`}
                data-gallery-id={galleryId}
                data-index={i}
              />
            </SwiperSlide>
          ))}
        </SwiperWrapper>
        <SwiperButtonPrev />
        <SwiperButtonNext />
      </Swiper>
    ) : (
      <img
        src={images[0]}
        alt={name}
        data-gallery-id={galleryId}
        data-index={0}
      />
    )}
    {status !== 'available' && (
      <span class={`status-badge status-${status}`}>{statusLabel[status]}</span>
    )}
  </div>

  <LightGallery id={galleryId} class="product-gallery-hidden">
    {images.map((img, i) => (
      <a href={img}>
        <img src={img} alt={`${name} ${i + 1}`} loading="lazy" />
      </a>
    ))}
  </LightGallery>

  <div class="clothing-info">
    <span class="item-name">{name}</span>
    <span class="item-price">${price.toFixed(2)}</span>
  </div>
  {isUnavailable ? (
    <span class="shop-btn shop-btn--disabled">{statusLabel[status]}</span>
  ) : (
    <a href={url} target="_blank" class="shop-btn">COMPRAR EN LA TIENDA</a>
  )}
</div>

<script>
  import { getLightGalleryFromUniqueSelector } from 'astro-lightgallery';

  document.addEventListener('click', async (e) => {
    const target = e.target as HTMLElement;
    const img = target.closest<HTMLElement>('[data-gallery-id]');
    if (!img) return;

    const galleryId = img.dataset.galleryId;
    const index = parseInt(img.dataset.index ?? '0', 10);
    if (!galleryId) return;

    const lg = await getLightGalleryFromUniqueSelector(`#${galleryId}`);
    lg?.openGallery(index);
  });
</script>

<style is:global>
  .product-gallery-hidden {
    display: none !important;
  }

  .clothing-img-wrapper {
    overflow: hidden;
  }

  .product-swiper {
    display: block;
    width: 100%;
    min-width: 0;
    height: 190px;
    overflow: hidden;
  }

  .product-swiper .swiper-wrapper,
  .product-swiper .swiper-slide {
    height: 190px !important;
  }

  .product-swiper .swiper-slide img {
    width: 100%;
    height: 190px;
    object-fit: contain;
    cursor: zoom-in;
    display: block;
  }

  .clothing-img-wrapper > img {
    cursor: zoom-in;
  }

  .product-swiper .swiper-button-prev,
  .product-swiper .swiper-button-next {
    --swiper-navigation-size: 16px;
    --swiper-navigation-color: var(--accent);
    width: 30px;
    height: 30px;
    border-radius: 2px;
    margin-top: 0;
    top: 50%;
    transform: translateY(-50%);
  }
</style>
