---
import { LightGallery } from 'astro-lightgallery';
import { YouTube } from 'astro-embed';

interface Props {
  title: string;
  date: Date;
  time?: string;
  venue: string;
  city: string;
  country: string;
  ticketUrl?: string;
  soldOut?: boolean;
  status?: 'proximamente' | 'cancelado' | 'terminado';
  description?: string;
  artists?: string[];
  images?: string[];
  flyer?: string;
  recap?: string;
}
const { title, date, time, venue, city, country, ticketUrl, soldOut, status, description, artists, images, flyer, recap } = Astro.props;
const resolvedStatus = status ?? (date < new Date() ? 'terminado' : 'proximamente');
const formattedDate = date
  .toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' })
  .toUpperCase();

function extractYouTubeId(input: string): string {
  const watchMatch = input.match(/[?&]v=([^&]+)/);
  if (watchMatch) return watchMatch[1];
  const shortMatch = input.match(/youtu\.be\/([^?&]+)/);
  if (shortMatch) return shortMatch[1];
  return input;
}

const youtubeId = recap ? extractYouTubeId(recap) : null;
const hasDetails = description || time || (artists && artists.length > 0) || (images && images.length > 0) || flyer || recap;
const galleryId = `show-lg-${Math.random().toString(36).slice(2, 9)}`;
const flyerGalleryId = `show-flyer-${Math.random().toString(36).slice(2, 9)}`;
const recapModalId = `show-recap-${Math.random().toString(36).slice(2, 9)}`;
---
<details class:list={['show-item', resolvedStatus]} data-venue={venue.toLowerCase()} data-title={title.toLowerCase()} data-status={resolvedStatus}>
  <summary class="show-summary">
    <div class="show-meta">
      <span class="show-date">{formattedDate}</span>
      <span class="show-venue">{venue}, {city}</span>
    </div>
    <div class="show-title-row">
      <div class="show-title">{title}</div>
    </div>
    <div style="display:flex; flex-direction: row; justify-content: space-between; align-items: center;">
          {resolvedStatus === 'terminado'
      ? youtubeId
        ? <div class="show-btn show-recap-btn" data-recap-modal-id={recapModalId} onclick="event.preventDefault()">VER RECAPITULACION</div>
        : <span class="show-btn show-status-btn terminado">TERMINADO</span>
      : resolvedStatus === 'cancelado'
      ? <span class="show-btn show-status-btn cancelado">CANCELADO</span>
      : soldOut
      ? <span class="show-btn sold-out">AGOTADAS</span>
      : <a href={ticketUrl} target="_blank" class="show-btn show-ticket-btn" onclick="event.preventDefault();window.open(this.href,'_blank')">COMPRAR ENTRADAS</a>
    }
          {hasDetails && <span class="show-expand-icon"></span>}
    </div>
  </summary>
  {hasDetails && (
    <div class="show-details">
      {description && <p class="show-description">{description}</p>}
      <div class="show-details-grid">
        <div class="show-detail-row">
          <span class="show-detail-label">FECHA</span>
          <span class="show-detail-value">{formattedDate}{time && ` · ${time}HS`}</span>
        </div>
        <div class="show-detail-row">
          <span class="show-detail-label">LUGAR</span>
          <span class="show-detail-value">{venue}, {city}, {country}</span>
        </div>
        {artists && artists.length > 0 && (
          <div class="show-detail-row">
            <span class="show-detail-label">ARTISTAS</span>
            <span class="show-detail-value">{artists.join(' · ')}</span>
          </div>
        )}
      </div>
      {(flyer || recap) && (
        <div class="show-action-row">
          {flyer && (
            <>
              <LightGallery id={flyerGalleryId} class="show-gallery-hidden">
                <a href={flyer}>
                  <img src={flyer} alt={`${title} flyer`} loading="lazy" />
                </a>
              </LightGallery>
              <div class="grid-item show-flyer-btn" data-flyer-gallery-id={flyerGalleryId}>VER FLYER</div>
            </>
          )}
          {youtubeId && (
            <div class="grid-item show-recap-btn" data-recap-modal-id={recapModalId}>VER RECAPITULACION</div>
          )}
        </div>
      )}
      {youtubeId && (
        <div class="show-recap-modal" id={recapModalId} aria-hidden="true">
          <div class="show-recap-backdrop"></div>
          <div class="show-recap-content">
            <button class="show-recap-close" aria-label="Cerrar">✕</button>
            <YouTube id={youtubeId} />
          </div>
        </div>
      )}
      {images && images.length > 0 && (
        <>
          <LightGallery id={galleryId} class="show-gallery-hidden">
            {images.map((img, i) => (
              <a href={img}>
                <img src={img} alt={`${title} ${i + 1}`} loading="lazy" />
              </a>
            ))}
          </LightGallery>
          <div class="show-photo-grid">
            {images.map((img, i) => (
              <div class="grid-item show-grid-item" data-gallery-id={galleryId} data-index={i}>
                <img src={img} alt={`${title} ${i + 1}`} loading="lazy" />
              </div>
            ))}
          </div>
        </>
      )}
    </div>
  )}
</details>

<script>
  import { getLightGalleryFromUniqueSelector } from 'astro-lightgallery';

  function teleportModals() {
    document.querySelectorAll<HTMLElement>('.show-recap-modal').forEach(modal => {
      if (modal.parentElement !== document.body) {
        document.body.appendChild(modal);
      }
    });
  }

  teleportModals();
  document.addEventListener('astro:page-load', teleportModals);

  function openRecapModal(modalId: string) {
    const modal = document.getElementById(modalId);
    if (!modal) return;
    modal.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }

  function closeRecapModal(modal: HTMLElement) {
    modal.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  document.addEventListener('click', async (e) => {
    const target = e.target as HTMLElement;

    const recapBtn = target.closest<HTMLElement>('.show-recap-btn');
    if (recapBtn) {
      e.preventDefault();
      e.stopPropagation();
      const modalId = recapBtn.dataset.recapModalId;
      if (modalId) openRecapModal(modalId);
      return;
    }

    const closeBtn = target.closest<HTMLElement>('.show-recap-close');
    if (closeBtn) {
      const modal = closeBtn.closest<HTMLElement>('.show-recap-modal');
      if (modal) closeRecapModal(modal);
      return;
    }

    const backdrop = target.closest<HTMLElement>('.show-recap-backdrop');
    if (backdrop) {
      const modal = backdrop.closest<HTMLElement>('.show-recap-modal');
      if (modal) closeRecapModal(modal);
      return;
    }

    const flyerBtn = target.closest<HTMLElement>('.show-flyer-btn');
    if (flyerBtn) {
      e.preventDefault();
      e.stopPropagation();
      const flyerGalleryId = flyerBtn.dataset.flyerGalleryId;
      if (!flyerGalleryId) return;
      const lg = await getLightGalleryFromUniqueSelector(`#${flyerGalleryId}`);
      lg?.openGallery(0);
      return;
    }

    const item = target.closest<HTMLElement>('.show-grid-item');
    if (!item) return;

    const galleryId = item.dataset.galleryId;
    const index = parseInt(item.dataset.index ?? '0', 10);
    if (!galleryId) return;

    const lg = await getLightGalleryFromUniqueSelector(`#${galleryId}`);
    lg?.openGallery(index);
  });

  document.addEventListener('keydown', (e) => {
    if (e.key !== 'Escape') return;
    document.querySelectorAll<HTMLElement>('.show-recap-modal[aria-hidden="false"]').forEach(closeRecapModal);
  });
</script>

<style is:global>
  .show-gallery-hidden {
    display: none !important;
  }

  .show-recap-modal {
    position: fixed;
    inset: 0;
    z-index: 10000;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .show-recap-modal[aria-hidden="true"] {
    display: none;
  }

  .show-recap-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.88);
    cursor: pointer;
  }

  .show-recap-content {
    position: relative;
    z-index: 1;
    width: min(720px, 92vw);
    border: 1px solid var(--ui-border);
    background: #111;
  }

  .show-recap-close {
    position: absolute;
    top: -32px;
    right: -10px;
    background: transparent;
    border: none;
    color: var(--text-grey);
    font-size: 14px;
    /* font-family: monospace; */
    cursor: pointer;
    letter-spacing: 1px;
    padding: 4px 8px;
  }

  .show-recap-close:hover {
    color: var(--accent);
  }

  .show-recap-content lite-youtube,
  .show-recap-content iframe {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    border: none;
  }
</style>
