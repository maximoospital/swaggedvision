---
import { SEO } from 'astro-seo';
import { SITE } from '../config/site';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  image?: string;
  noindex?: boolean;
}

const {
  title,
  description = SITE.description,
  canonical,
  image = SITE.logo,
  noindex = false,
} = Astro.props;

const pageTitle = `${title} | ${SITE.shortName}`;
const pageUrl = canonical ?? new URL(Astro.url.pathname, SITE.url).href;
const imageUrl = new URL(image, SITE.url).href;
---
<SEO
  title={pageTitle}
  description={description}
  canonical={pageUrl}
  noindex={noindex}
  openGraph={{
    basic: {
      title: pageTitle,
      type: 'website',
      image: imageUrl,
      url: pageUrl,
    },
    optional: {
      description,
      locale: 'en_US',
      siteName: SITE.name,
    },
    image: { alt: SITE.name },
  }}
  twitter={{
    card: 'summary_large_image',
    title: pageTitle,
    description,
    image: imageUrl,
    imageAlt: SITE.name,
  }}
  extend={{
    meta: [
      { name: 'theme-color', content: SITE.themeColor },
      { name: 'robots', content: noindex ? 'noindex,nofollow' : 'index,follow' },
    ],
    link: [
      { rel: 'icon', href: '/favicon.ico' },
    ],
  }}
/>
