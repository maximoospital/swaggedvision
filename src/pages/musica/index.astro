---
import BaseLayout from '../../layouts/baseLayout.astro';
import MusicItem from '../../components/MusicItem.astro';
import { getCollection } from 'astro:content';
import { SITE } from '../../config/site';

const releases = (await getCollection('musica')).sort((a, b) => (b.data.year ?? 0) - (a.data.year ?? 0));

const schema = releases.length === 1
  ? {
      '@context': 'https://schema.org',
      '@type': 'MusicAlbum',
      name: releases[0].data.title,
      byArtist: {
        '@type': 'MusicGroup',
        name: SITE.shortName,
        url: SITE.url,
      },
      ...(releases[0].data.trackCount && { numTracks: releases[0].data.trackCount }),
      genre: releases[0].data.genres,
    }
  : {
      '@context': 'https://schema.org',
      '@type': 'ItemList',
      name: SITE.shortName,
      itemListElement: releases.map((release, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        item: {
          '@type': 'MusicAlbum',
          name: release.data.title,
          byArtist: { '@type': 'MusicGroup', name: SITE.name, url: SITE.url },
          genre: release.data.genres,
        },
      })),
    };
---
<BaseLayout
  title="Musica"
  description="Musica SWVS. Escuchala ya."
  {schema}
  section="musica"
>
  <div class="content-panel panel-musica" transition:name="panel">
    <div class="panel-header">
      <span class="panel-id">SWVS_TEMONES</span>
      <h2>MUSICA SWVS</h2>
    </div>
    <div class="music-releases">
      {releases.length === 0
        ? <p class="proximamente">Proximamente... faa...</p>
        : releases.map(release => <MusicItem id={release.id} {...release.data} />)
      }
    </div>
  </div>
</BaseLayout>
