---
import BaseLayout from '../../layouts/baseLayout.astro';
import MusicItem from '../../components/MusicItem.astro';
import { getCollection } from 'astro:content';

const releases = await getCollection('musica');

const schema = releases.length === 1
  ? {
      '@context': 'https://schema.org',
      '@type': 'MusicAlbum',
      name: releases[0].data.title,
      byArtist: {
        '@type': 'MusicGroup',
        name: 'SWVS',
        url: 'https://swaggedvision.com',
      },
      ...(releases[0].data.trackCount && { numTracks: releases[0].data.trackCount }),
      genre: releases[0].data.genres,
    }
  : {
      '@context': 'https://schema.org',
      '@type': 'ItemList',
      name: 'SWVS.',
      itemListElement: releases.map((release, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        item: {
          '@type': 'MusicAlbum',
          name: release.data.title,
          byArtist: { '@type': 'MusicGroup', name: 'SWAGGEDVISION' },
          genre: release.data.genres,
        },
      })),
    };
---
<BaseLayout
  title="Musica"
  description="Musica SWVS. Escuchala ya."
  {schema}
  section="musica"
>
  <div class="content-panel panel-musica" transition:name="panel">
    <div class="panel-header">
      <span class="panel-id">SWVS_TEMONES</span>
      <h2>MUSICA SWVS</h2>
    </div>
    <div class="music-releases">
      {releases.map(release => <MusicItem id={release.id} {...release.data} />)}
    </div>
  </div>
</BaseLayout>
